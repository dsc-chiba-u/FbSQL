<mxfile host="app.diagrams.net" type="device">
  <diagram id="fbsql-figure1" name="Figure 1 — System overview">
    <mxGraphModel dx="1000" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1360" pageHeight="880" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- language layer -->
        <mxCell id="lang" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px&quot; color=&quot;#4477AA&quot;&gt;FbSQL — the language&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#4477AA&quot;&gt;what the user writes and what is guaranteed; every arrow is a relation&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#F0F5FB;strokeColor=#4477AA;verticalAlign=top;align=left;spacing=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1320" height="560" as="geometry" />
        </mxCell>

        <mxCell id="training" value="&lt;b&gt;Training relation&lt;/b&gt;&lt;br&gt;any SQL query"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#4477AA;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="190" width="190" height="100" as="geometry" />
        </mxCell>

        <mxCell id="formula" value="&#39;churn_flag ~ age + gender&#39;"
                style="text;html=1;align=center;fontSize=10;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="290" y="150" width="220" height="20" as="geometry" />
        </mxCell>

        <mxCell id="fit" value="&lt;b&gt;fit_glm()&lt;/b&gt;&lt;br&gt;formula, family"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#4477AA;strokeWidth=1.5;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="190" width="180" height="100" as="geometry" />
        </mxCell>

        <mxCell id="model" value="&lt;font style=&quot;font-size: 15px&quot; color=&quot;#7A4A00&quot;&gt;&lt;b&gt;Model relation&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px&quot; face=&quot;Helvetica&quot;&gt;term&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;estimate&amp;nbsp;&amp;nbsp;…&amp;nbsp;&amp;nbsp;aic&lt;br&gt;(Intercept)&amp;nbsp;&amp;nbsp;−12.11&amp;nbsp;&amp;nbsp;…&lt;br&gt;age&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;0.30&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;…&lt;br&gt;genderM&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;−0.43&amp;nbsp;&amp;nbsp;…&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#FFF7E6;strokeColor=#CC7722;strokeWidth=3;verticalAlign=top;spacing=10;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="130" width="330" height="280" as="geometry" />
        </mxCell>

        <mxCell id="meta" value="metadata: xlevels · contrasts · terms"
                style="rounded=1;html=1;fillColor=#FDEBD0;strokeColor=#CC7722;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="330" width="290" height="34" as="geometry" />
        </mxCell>

        <mxCell id="modelnote" value="&lt;i&gt;queryable · joinable · auditable · self-contained&lt;/i&gt;"
                style="text;html=1;align=center;fontSize=11;fontColor=#7A4A00;" vertex="1" parent="1">
          <mxGeometry x="540" y="374" width="330" height="24" as="geometry" />
        </mxCell>

        <mxCell id="scoring" value="&lt;b&gt;Scoring relation&lt;/b&gt;&lt;br&gt;any SQL query"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#4477AA;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="910" y="40" width="190" height="90" as="geometry" />
        </mxCell>

        <mxCell id="predict" value="&lt;b&gt;predict_glm()&lt;/b&gt;&lt;br&gt;on_new_levels"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#4477AA;strokeWidth=1.5;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="910" y="190" width="190" height="100" as="geometry" />
        </mxCell>

        <mxCell id="prediction" value="&lt;b&gt;Prediction relation&lt;/b&gt;&lt;br&gt;+ &amp;lt;response&amp;gt;_predicted"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#4477AA;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1160" y="190" width="180" height="100" as="geometry" />
        </mxCell>

        <!-- implementation layer -->
        <mxCell id="impl" value="&lt;b&gt;Reference implementation — PostgreSQL extension&lt;/b&gt;&lt;br&gt;replaceable engine: the SQL above never changes"
                style="rounded=1;html=1;fillColor=#F5F5F5;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;spacing=12;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="20" y="650" width="1320" height="210" as="geometry" />
        </mxCell>

        <mxCell id="plr" value="&lt;b&gt;PL/R → stats::glm()&lt;/b&gt;&lt;br&gt;fitting engine (R as oracle)"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=12;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="300" y="720" width="250" height="90" as="geometry" />
        </mxCell>

        <mxCell id="plpgsql" value="&lt;b&gt;PL/pgSQL — no R&lt;/b&gt;&lt;br&gt;predicts from the model relation alone"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=12;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="850" y="720" width="310" height="90" as="geometry" />
        </mxCell>

        <mxCell id="future" value="&lt;i&gt;future engines:&lt;br&gt;C · GPU · distributed&lt;/i&gt;"
                style="text;html=1;align=center;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="620" y="740" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="boundary" value="&lt;i&gt;language / engine boundary&lt;/i&gt;"
                style="text;html=1;align=right;fontSize=10;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="1120" y="605" width="220" height="20" as="geometry" />
        </mxCell>

        <!-- flows -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#333333;strokeWidth=1.5;" edge="1" parent="1" source="training" target="fit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#CC7722;strokeWidth=1.5;" edge="1" parent="1" source="fit" target="model">
