<mxfile host="app.diagrams.net" type="device">
  <diagram id="fbsql-figure4" name="Figure 4 — SQL-ML system taxonomy">
    <mxGraphModel dx="1000" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1360" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="g1" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px&quot; color=&quot;#4477AA&quot;&gt;In-database SQL-ML&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#4477AA&quot;&gt;ML runs inside the DBMS, called as SQL functions&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#F0F5FB;strokeColor=#4477AA;strokeWidth=1.5;verticalAlign=top;spacing=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="410" height="620" as="geometry" />
        </mxCell>
        <mxCell id="fbsql" value="&lt;b&gt;FbSQL (this paper)&lt;/b&gt;&lt;br&gt;set-returning SQL functions&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;model = a relation&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#CC7722;strokeWidth=2.5;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="140" width="350" height="130" as="geometry" />
        </mxCell>
        <mxCell id="madlib" value="&lt;b&gt;Apache MADlib&lt;/b&gt;&lt;br&gt;procedure-style SQL calls&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;model = side-effect tables&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#4477AA;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="300" width="350" height="130" as="geometry" />
        </mxCell>
        <mxCell id="pgml" value="&lt;b&gt;PostgresML&lt;/b&gt;&lt;br&gt;task + algorithm SQL API&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;model = binary in catalogs&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#4477AA;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="460" width="350" height="130" as="geometry" />
        </mxCell>

        <mxCell id="g2" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px&quot; color=&quot;#555555&quot;&gt;SQL-on-engine ML&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;SQL defines relations on a query engine; ML lives beside the SQL&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#F5F5F5;strokeColor=#999999;strokeWidth=1.5;verticalAlign=top;spacing=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="40" width="410" height="620" as="geometry" />
        </mxCell>
        <mxCell id="spark" value="&lt;b&gt;Spark MLlib&lt;/b&gt;&lt;br&gt;RFormula + DataFrame / Pipeline&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;model = host-language object&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="510" y="140" width="350" height="130" as="geometry" />
        </mxCell>
        <mxCell id="hivemall" value="&lt;b&gt;Apache Hivemall&lt;/b&gt;&lt;br&gt;UDFs inside HiveQL&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;model = (feature, weight) table&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="510" y="300" width="350" height="130" as="geometry" />
        </mxCell>

        <mxCell id="g3" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px&quot; color=&quot;#555555&quot;&gt;SQL-adjacent ML&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;reached from SQL only by converting the data out&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#F5F5F5;strokeColor=#999999;strokeWidth=1.5;dashed=1;verticalAlign=top;spacing=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="40" width="400" height="620" as="geometry" />
        </mxCell>
        <mxCell id="h2o" value="&lt;b&gt;H2O-3 + Sparkling Water&lt;/b&gt;&lt;br&gt;DataFrame → H2OFrame&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;model = binary in ML cluster&lt;/font&gt;"
                style="rounded=1;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="950" y="140" width="340" height="130" as="geometry" />
        </mxCell>

        <mxCell id="foot" value="&lt;i&gt;grouped by where the modeling computation lives relative to the SQL language — a typology, not a ranking&lt;/i&gt;"
                style="text;html=1;align=center;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="180" y="690" width="1000" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
